VITE_MAPBOX_TOKEN=your_mapbox_token_here
VITE_POSTHOG_KEY=your_posthog_project_api_key
# eBird token — server-side only (used by api/ebird.js + scripts/prebuild-stats.js).
# NOT VITE_-prefixed: it must never ship in the browser bundle. eBird caps keys
# at 10,000 req/day + 1 req/sec, so all eBird traffic is proxied + edge-cached.
EBIRD_API_KEY=your_ebird_api_key

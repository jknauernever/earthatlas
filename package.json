    "@vercel/blob": "^2.4.0",
    "mapbox-gl": "^3.24.1",
    "pmtiles": "^4.4.1",
    "posthog-js": "^1.356.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@sentry/vite-plugin": "^5.3.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "eslint": "^9.9.0",
